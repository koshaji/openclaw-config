#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = []
# ///
"""
check-auth — OpenClaw Phase 2 allowlist authorization check

Usage:
    check-auth <identity>

Arguments:
    identity    Sender identity in format platform:id
                Examples: telegram:833846354, discord:987654321

Output:
    PERMIT      Identity is authorized (or no allowlist file exists)
    DENY        Identity is not in the allowlist

Exit codes:
    0           PERMIT
    1           DENY
    2           Usage error

Audit:
    DENY events are logged to ~/.openclaw/audit/auth-denials.jsonl
"""

import sys
import json
import time
from pathlib import Path

AUTHORIZED_USERS_FILE = Path.home() / ".openclaw" / "authorized-users"
AUDIT_DIR = Path.home() / ".openclaw" / "audit"
AUDIT_DENIALS_FILE = AUDIT_DIR / "auth-denials.jsonl"


def log_denial(sender: str, reason: str) -> None:
    """Append a DENY event to the audit log."""
    try:
        AUDIT_DIR.mkdir(parents=True, exist_ok=True)
        entry = {
            "ts": int(time.time()),
            "action": "auth_denied",
            "sender": sender,
            "reason": reason,
        }
        with AUDIT_DENIALS_FILE.open("a") as f:
            f.write(json.dumps(entry) + "\n")
    except Exception as e:
        print(f"WARNING: could not write audit log: {e}", file=sys.stderr)


def load_allowlist(path: Path) -> set[str]:
    """Parse the authorized-users file, ignoring comments and blank lines."""
    allowed: set[str] = set()
    with path.open() as f:
        for line in f:
            line = line.strip()
            # Skip blank lines and comments
            if not line or line.startswith("#"):
                continue
            allowed.add(line)
    return allowed


def check_auth(identity: str) -> bool:
    """
    Returns True if identity is permitted, False if denied.
    If the authorized-users file doesn't exist, permits everyone.
    """
    if not AUTHORIZED_USERS_FILE.exists():
        # No allowlist configured — opt-in security, default permit
        return True

    try:
        allowlist = load_allowlist(AUTHORIZED_USERS_FILE)
    except Exception as e:
        print(f"WARNING: could not read authorized-users file: {e}", file=sys.stderr)
        # Fail open (backward compatible) — could change to fail closed in Phase 3
        return True

    return identity in allowlist


def main() -> int:
    if len(sys.argv) != 2 or sys.argv[1] in ("-h", "--help"):
        print(__doc__.strip())
        return 2

    identity = sys.argv[1].strip()

    if not identity:
        print("ERROR: identity cannot be empty", file=sys.stderr)
        return 2

    # Validate format loosely
    if ":" not in identity:
        print(
            f"WARNING: identity '{identity}' doesn't look like platform:id format",
            file=sys.stderr,
        )

    permitted = check_auth(identity)

    if permitted:
        print("PERMIT")
        return 0
    else:
        reason = "user not in allowlist"
        log_denial(identity, reason)
        print("DENY")
        return 1


if __name__ == "__main__":
    sys.exit(main())
