AGENTS_DIR = OPENCLAW_DIR / "agents"

# ---------------------------------------------------------------------------
# VERIFIED SESSION LOG SCHEMA (C3 verification — 2026-03-28)
# ---------------------------------------------------------------------------
# Verified against real session logs in ~/.openclaw/agents/*/sessions/*.jsonl
#
# Each line in a session JSONL file is one of these event types:
#   type="session"  — session metadata (version, cwd, timestamp)
#   type="message"  — an LLM turn (user or assistant)
#   type="model_change" — model switch within session
#   type="custom"   — custom events
#
# USAGE DATA is present on type="message" lines where the assistant called
# the LLM API. The relevant fields (all at top level of the JSON object):
#
#   {
#     "type": "message",
#     "id": "<8-char hex>",
#     "timestamp": "2026-03-22T04:01:14.894Z",   ← ISO 8601 UTC
#     "provider": "anthropic",                    ← provider prefix
#     "model": "claude-opus-4-6",                 ← model ID (no prefix)
#     "usage": {
#       "input": 12345,        ← input tokens
#       "output": 678,         ← output tokens
#       "cacheRead": 9000,     ← cache read tokens (Anthropic prompt caching)
#       "cacheWrite": 300,     ← cache write tokens
#       "total": 22323         ← total tokens (sum of above)
#     }
#   }
#
# NOTE: Many entries have usage.input=0, usage.output=0 — these are
# NO_REPLY heartbeat messages and other non-substantive turns. They are
# included in the count but contribute $0.00 cost, which is correct.
#
# The cost-tracker correctly reads: usage.input, usage.output,
# usage.cacheRead, usage.cacheWrite — matching the verified schema above.
#
# Model key normalisation: provider="anthropic" + model="claude-opus-4-6"
# → key="anthropic/claude-opus-4-6" matches DEFAULT_PRICING keys. ✓


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------


def ensure_costs_dir() -> None:
    """Create ~/.openclaw/costs/ and default pricing.json if missing."""
    COSTS_DIR.mkdir(parents=True, exist_ok=True)
    if not PRICING_FILE.exists():
        PRICING_FILE.write_text(json.dumps(DEFAULT_PRICING, indent=2) + "\n")
        print(
            f"[cost-tracker] Created default pricing config at {PRICING_FILE}",
            file=sys.stderr,
        )


def load_pricing() -> dict[str, dict[str, float]]:
    ensure_costs_dir()
    try:
        return json.loads(PRICING_FILE.read_text())
    except Exception as e:
        print(f"[cost-tracker] Warning: could not load pricing.json: {e}", file=sys.stderr)
        return DEFAULT_PRICING


def calc_cost(
    pricing: dict[str, dict[str, float]],
    model_key: str,
    input_tokens: int,
    output_tokens: int,
    cache_read_tokens: int,
    cache_write_tokens: int,
) -> float:
    """Return estimated USD cost for a set of token counts."""
    # Try exact key, then normalised variants
    p = pricing.get(model_key)
    if p is None:
        # Try stripping provider prefix: "claude-sonnet-4-6"
        short = model_key.split("/")[-1] if "/" in model_key else model_key
        for k, v in pricing.items():
            if k.split("/")[-1] == short:
                p = v
                break
    if p is None:
        return 0.0

    cost = (
        input_tokens * p.get("input_per_1m", 0) / 1_000_000
        + output_tokens * p.get("output_per_1m", 0) / 1_000_000
        + cache_read_tokens * p.get("cache_read_per_1m", 0) / 1_000_000
        + cache_write_tokens * p.get("cache_write_per_1m", 0) / 1_000_000
    )
    return cost


def parse_timestamp(raw: str | None, fallback: float) -> datetime:
    """Return a UTC datetime from an ISO string or epoch fallback."""
    if raw:
        try:
            # Handle both "Z" suffix and "+00:00"
            raw = raw.replace("Z", "+00:00")
            return datetime.fromisoformat(raw).astimezone(timezone.utc)
        except ValueError:
            pass
    return datetime.fromtimestamp(fallback, tz=timezone.utc)


def model_key_from_line(line: dict[str, Any]) -> str:
    """Build a canonical provider/modelId key from a JSONL line."""
    provider = line.get("provider", "").lower()
    model_id = line.get("modelId", line.get("model", ""))
    if not model_id:
        return "unknown"
    if provider and not model_id.startswith(provider + "/"):
        return f"{provider}/{model_id}"
    return model_id


def agent_name_from_path(path: Path) -> str:
    """Extract agent name from ~/.openclaw/agents/<name>/sessions/file.jsonl"""
    try:
        # path.parts: [..., "agents", "<name>", "sessions", "file.jsonl"]
        agents_idx = list(path.parts).index("agents")
        return path.parts[agents_idx + 1]
    except (ValueError, IndexError):
        return path.parent.parent.name


# ---------------------------------------------------------------------------
# Core aggregation
# ---------------------------------------------------------------------------


def collect_records(
    target_dates: set[date],
    agent_filter: str | None = None,
) -> list[dict[str, Any]]:
    """
    Scan all session JSONL files and return usage records for target_dates.
    Each record: {date, agent, model, input, output, cache_read, cache_write}
    """
    pattern = str(AGENTS_DIR / "*" / "sessions" / "*.jsonl")
    files = glob.glob(pattern)

    records: list[dict[str, Any]] = []

    for fpath in files:
        fp = Path(fpath)
        agent = agent_name_from_path(fp)
        if agent_filter and agent != agent_filter:
            continue

        file_mtime = fp.stat().st_mtime

        try:
            with fp.open("r", encoding="utf-8", errors="replace") as f:
                for raw_line in f:
                    raw_line = raw_line.strip()
                    if not raw_line:
                        continue
                    try:
                        obj = json.loads(raw_line)
                    except json.JSONDecodeError:
                        continue

                    usage = obj.get("usage")
                    if not usage:
                        continue

                    ts = parse_timestamp(obj.get("timestamp"), file_mtime)
                    rec_date = ts.date()
                    if rec_date not in target_dates:
                        continue

                    model = model_key_from_line(obj)
                    records.append(
                        {
                            "date": rec_date,
                            "agent": agent,
                            "model": model,
                            "input": int(usage.get("input", 0)),
                            "output": int(usage.get("output", 0)),
                            "cache_read": int(usage.get("cacheRead", 0)),
                            "cache_write": int(usage.get("cacheWrite", 0)),
                        }
                    )
        except OSError:
            continue

    return records


def build_summary(
    records: list[dict[str, Any]],
    target_date: date,
    pricing: dict[str, dict[str, float]],
) -> dict[str, Any]:
    """Aggregate records into a daily summary dict."""

    by_agent: dict[str, dict[str, Any]] = defaultdict(
        lambda: {
            "input_tokens": 0,
            "output_tokens": 0,
            "cache_read_tokens": 0,
            "cache_write_tokens": 0,
            "calls": 0,
            "estimated_usd": 0.0,
        }
    )
    by_model: dict[str, dict[str, Any]] = defaultdict(
        lambda: {
            "calls": 0,
            "input_tokens": 0,
            "output_tokens": 0,
            "cache_read_tokens": 0,
            "cache_write_tokens": 0,
            "estimated_usd": 0.0,
        }
    )

    for r in records:
        cost = calc_cost(
            pricing,
            r["model"],
            r["input"],
            r["output"],
            r["cache_read"],
            r["cache_write"],
        )

        a = by_agent[r["agent"]]
        a["input_tokens"] += r["input"]
        a["output_tokens"] += r["output"]
        a["cache_read_tokens"] += r["cache_read"]
        a["cache_write_tokens"] += r["cache_write"]
        a["calls"] += 1
        a["estimated_usd"] += cost

        m = by_model[r["model"]]
        m["calls"] += 1
        m["input_tokens"] += r["input"]
        m["output_tokens"] += r["output"]
        m["cache_read_tokens"] += r["cache_read"]
        m["cache_write_tokens"] += r["cache_write"]
        m["estimated_usd"] += cost

    total_usd = sum(a["estimated_usd"] for a in by_agent.values())

    # Round costs for readability
    for a in by_agent.values():
        a["estimated_usd"] = round(a["estimated_usd"], 6)
    for m in by_model.values():
        m["estimated_usd"] = round(m["estimated_usd"], 6)

    return {
        "date": target_date.isoformat(),
        "by_agent": dict(by_agent),
        "by_model": dict(by_model),
        "total_estimated_usd": round(total_usd, 6),
        "generated_at": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
    }


def write_summary(summary: dict[str, Any]) -> Path:
    """Write summary JSON to ~/.openclaw/costs/YYYY-MM-DD.json."""
    ensure_costs_dir()
    out = COSTS_DIR / f"{summary['date']}.json"
    out.write_text(json.dumps(summary, indent=2) + "\n")
    return out


# ---------------------------------------------------------------------------
# Display
# ---------------------------------------------------------------------------


def fmt_tokens(n: int) -> str:
    if n >= 1_000_000:
        return f"{n / 1_000_000:.1f}M"
    if n >= 1_000:
        return f"{n / 1_000:.0f}K"
    return str(n)


def print_summary_text(summary: dict[str, Any], multi_day: bool = False) -> None:
    """Pretty-print a summary to stdout."""
    try:
        from rich.console import Console
        from rich.table import Table
        from rich import box

        console = Console()
        title = f"Cost Summary — {summary['date']}"
        console.print(f"\n[bold cyan]{title}[/bold cyan]")
        console.print("─" * 50)

        # By Agent
        t = Table(box=box.SIMPLE, show_header=True, header_style="bold")
        t.add_column("Agent", style="cyan")
        t.add_column("Calls", justify="right")
        t.add_column("Input", justify="right")
        t.add_column("Output", justify="right")
        t.add_column("Cache R/W", justify="right")
        t.add_column("Est. Cost", justify="right", style="green")
        for name, data in sorted(summary["by_agent"].items()):
            t.add_row(
                name,
                str(data["calls"]),
                fmt_tokens(data["input_tokens"]),
                fmt_tokens(data["output_tokens"]),
                f"{fmt_tokens(data['cache_read_tokens'])}/{fmt_tokens(data['cache_write_tokens'])}",
                f"${data['estimated_usd']:.4f}",
            )
        console.print(t)

        # By Model
        m = Table(box=box.SIMPLE, show_header=True, header_style="bold")
        m.add_column("Model", style="magenta")
        m.add_column("Calls", justify="right")
        m.add_column("Input", justify="right")
        m.add_column("Output", justify="right")
        m.add_column("Est. Cost", justify="right", style="green")
        for name, data in sorted(summary["by_model"].items()):
            m.add_row(
                name,
                str(data["calls"]),
                fmt_tokens(data["input_tokens"]),
                fmt_tokens(data["output_tokens"]),
                f"${data['estimated_usd']:.4f}",
            )
        console.print(m)

        console.print(
            f"[bold]Total:[/bold] [bold green]${summary['total_estimated_usd']:.4f}[/bold green]\n"
        )

    except ImportError:
        # Fallback without rich
        print(f"\nCost Summary — {summary['date']}")
        print("=" * 50)
        print("By Agent:")
        for name, data in sorted(summary["by_agent"].items()):
            print(
                f"  {name:<20} ${data['estimated_usd']:.4f}"
                f"  ({fmt_tokens(data['input_tokens'])} in"
                f" / {fmt_tokens(data['output_tokens'])} out)"
            )
        print("\nBy Model:")
        for name, data in sorted(summary["by_model"].items()):
            print(
                f"  {name:<40} ${data['estimated_usd']:.4f}"
                f"  {data['calls']} calls"
            )
        print(f"\nTotal: ${summary['total_estimated_usd']:.4f}\n")


def print_multi_day_summary(summaries: list[dict[str, Any]]) -> None:
    """Print a multi-day rollup."""
    # Aggregate across days
    total_usd = sum(s["total_estimated_usd"] for s in summaries)
    agent_totals: dict[str, float] = defaultdict(float)
    model_totals: dict[str, float] = defaultdict(float)

    for s in summaries:
        for agent, data in s["by_agent"].items():
            agent_totals[agent] += data["estimated_usd"]
        for model, data in s["by_model"].items():
            model_totals[model] += data["estimated_usd"]

    start = summaries[0]["date"] if summaries else "?"
    end = summaries[-1]["date"] if summaries else "?"

    print(f"\nCost Rollup — {start} → {end}  ({len(summaries)} days)")
    print("=" * 50)
    print("By Agent:")
    for name, usd in sorted(agent_totals.items()):
        print(f"  {name:<20} ${usd:.4f}")
    print("\nBy Model:")
    for name, usd in sorted(model_totals.items()):
        print(f"  {name:<40} ${usd:.4f}")
    print(f"\nTotal: ${total_usd:.4f}  (avg ${total_usd / max(len(summaries), 1):.4f}/day)\n")


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Estimate OpenClaw token costs from session logs.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  cost-tracker                       # today's costs
  cost-tracker --date 2026-03-27     # specific date
  cost-tracker --days 7              # last 7 days
  cost-tracker --agent atlas4        # filter by agent
  cost-tracker --output json         # JSON to stdout (also writes file)
""",
    )
    parser.add_argument("--date", metavar="YYYY-MM-DD", help="Target date (default: today)")
    parser.add_argument("--days", type=int, metavar="N", help="Summarize last N days")
    parser.add_argument("--agent", metavar="NAME", help="Filter to a single agent")
    parser.add_argument(
        "--output",
        choices=["text", "json"],
        default="text",
        help="Output format (default: text)",
    )
    args = parser.parse_args()

    pricing = load_pricing()

    if args.days:
        today = date.today()
        dates = [today - timedelta(days=i) for i in range(args.days - 1, -1, -1)]
        summaries = []
        for d in dates:
            records = collect_records({d}, agent_filter=args.agent)
            s = build_summary(records, d, pricing)
            write_summary(s)
            summaries.append(s)

        if args.output == "json":
            print(json.dumps(summaries, indent=2))
        else:
            print_multi_day_summary(summaries)
        return

    # Single date
    if args.date:
        try:
            target = date.fromisoformat(args.date)
        except ValueError:
            print(f"Error: invalid date '{args.date}' — expected YYYY-MM-DD", file=sys.stderr)
            sys.exit(1)
    else:
        target = date.today()

    records = collect_records({target}, agent_filter=args.agent)
    summary = build_summary(records, target, pricing)
    out_path = write_summary(summary)

    if args.output == "json":
        print(json.dumps(summary, indent=2))
    else:
        print_summary_text(summary)
        print(f"[saved to {out_path}]", file=sys.stderr)


if __name__ == "__main__":
    main()
