#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = []
# ///
"""
check-auth — OpenClaw Phase 2 allowlist authorization check

Usage:
    check-auth <identity>

Arguments:
    identity    Sender identity in format platform:id
                Examples: telegram:833846354, discord:987654321

Output:
    PERMIT      Identity is authorized (or no allowlist file exists)
    DENY        Identity is not in the allowlist

Exit codes:
    0           PERMIT
    1           DENY
    2           Usage error

Audit:
    DENY events are logged to ~/.openclaw/audit/auth-denials.jsonl
"""

import sys
import json
import time
from pathlib import Path

AUTHORIZED_USERS_FILE = Path.home() / ".openclaw" / "authorized-users"
AUDIT_DIR = Path.home() / ".openclaw" / "audit"
AUDIT_DENIALS_FILE = AUDIT_DIR / "auth-denials.jsonl"


def _daily_audit_file() -> Path:
    """Return path to today's structured audit log: ~/.openclaw/audit/YYYY-MM-DD.jsonl"""
    today = time.strftime("%Y-%m-%d", time.localtime())
    return AUDIT_DIR / f"{today}.jsonl"


def write_audit_event(sender: str, result: str, reason: str) -> None:
    """
    Write an auth event to BOTH:
      1. The daily structured audit log (~/.openclaw/audit/YYYY-MM-DD.jsonl)
      2. The denials-only legacy log (~/.openclaw/audit/auth-denials.jsonl)

    Standard audit entry format (from devops/audit-log.md):
      ts, agent, sender, action, resource, args, result, reason
    """
    try:
        AUDIT_DIR.mkdir(parents=True, exist_ok=True)
        entry = {
            "ts": int(time.time()),
            "agent": "check-auth",
            "sender": sender,
            "action": "auth_check",
            "resource": "check-auth",
            "args": sender,
            "result": result,
            "reason": reason,
        }
        # Write to daily structured log
        with _daily_audit_file().open("a") as f:
            f.write(json.dumps(entry) + "\n")
        # Also write to denials-only log for backward compatibility
        if result == "DENY":
            denial_entry = {
                "ts": entry["ts"],
                "action": "auth_denied",
                "sender": sender,
                "reason": reason,
            }
            with AUDIT_DENIALS_FILE.open("a") as f:
                f.write(json.dumps(denial_entry) + "\n")
    except Exception as e:
        print(f"WARNING: could not write audit log: {e}", file=sys.stderr)


def log_denial(sender: str, reason: str) -> None:
    """Backward-compat wrapper — use write_audit_event instead."""
    write_audit_event(sender, "DENY", reason)


def load_allowlist(path: Path) -> set[str]:
    """Parse the authorized-users file, ignoring comments and blank lines."""
    allowed: set[str] = set()
    with path.open() as f:
        for line in f:
            line = line.strip()
            # Skip blank lines and comments
            if not line or line.startswith("#"):
                continue
            allowed.add(line)
    return allowed


def check_auth(identity: str) -> bool:
    """
    Returns True if identity is permitted, False if denied.
    If the authorized-users file doesn't exist, permits everyone.
    """
    if not AUTHORIZED_USERS_FILE.exists():
        # No allowlist configured — opt-in security, default permit
        return True

    try:
        allowlist = load_allowlist(AUTHORIZED_USERS_FILE)
    except Exception as e:
        # Fail CLOSED: if the file exists but can't be read, that's a security error.
        # Silently permitting access when the allowlist is unreadable would disable
        # all access control on disk errors or permission changes.
        print(f"ERROR: authorized-users file exists but could not be read: {e}", file=sys.stderr)
        print(f"ERROR: Failing closed (DENY) to preserve security posture", file=sys.stderr)
        return False

    return identity in allowlist


def main() -> int:
    if len(sys.argv) != 2 or sys.argv[1] in ("-h", "--help"):
        print(__doc__.strip())
        return 2

    identity = sys.argv[1].strip()

    if not identity:
        print("ERROR: identity cannot be empty", file=sys.stderr)
        return 2

    # Validate format loosely
    if ":" not in identity:
        print(
            f"WARNING: identity '{identity}' doesn't look like platform:id format",
            file=sys.stderr,
        )

    permitted = check_auth(identity)

    if permitted:
        write_audit_event(identity, "PERMIT", "user in allowlist" if AUTHORIZED_USERS_FILE.exists() else "no allowlist configured")
        print("PERMIT")
        return 0
    else:
        reason = "user not in allowlist"
        write_audit_event(identity, "DENY", reason)
        print("DENY")
        return 1


if __name__ == "__main__":
    sys.exit(main())
